{
  "name": "osv-check",
  "version": "1.0.0",
  "description": "CLI tool to check npm packages for known vulnerabilities using the OSV.dev API",
  "type": "module",
  "bin": {
    "osv-check": "bin/osv-check.js"
  },
  "main": "./src/api.js",
  "exports": {
    ".": "./src/api.js"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "osv",
    "scanner",
    "audit",
    "npm"
  ],
  "author": "Marcos Reuquen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcosreuquen/osv-check.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
