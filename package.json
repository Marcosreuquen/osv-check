{
  "name": "@marcosreuquen/osv-check",
  "version": "1.1.0",
  "description": "CLI tool to check packages for known vulnerabilities using the OSV.dev API (npm, PyPI, and more)",
  "type": "module",
  "bin": {
    "osv-check": "bin/osv-check.js"
  },
  "main": "./src/api.js",
  "exports": {
    ".": "./src/api.js"
  },
  "scripts": {
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest",
    "prepare": "git config core.hooksPath .githooks"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "osv",
    "scanner",
    "audit",
    "npm",
    "pypi",
    "pip",
    "multi-ecosystem"
  ],
  "author": "Marcos Reuquen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcosreuquen/osv-check.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0"
  }
}
